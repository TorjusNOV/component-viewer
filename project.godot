; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Component Viewer"
run/main_scene="uid://cny2g8v4pvbtm"
config/features=PackedStringArray("4.6", "Mobile")
boot_splash/bg_color=Color(1, 1, 1, 1)
boot_splash/show_image=false
config/icon="res://icon.svg"

[blenderkit]

materials/api_key=""
materials/resolution="resolution_2K"
materials/model_format="gltf_godot"
materials/assets_path="user://blenderkit_downloads"
materials/search_free_only=true
materials/assets_path_migrated_to_user=true

[display]

window/size/mode=1
window/size/borderless=true
window/size/sharp_corners=true
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/Gizmo3DScript/plugin.cfg")

[input]

toggle_editor_mode={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194306,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
